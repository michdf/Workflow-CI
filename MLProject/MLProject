name: iris-rul

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators: {type: int, default: 100}
      min_samples_split: {type: int, default: 2}
      min_samples_leaf: {type: int, default: 2}
      max_depth: {type: int, default: 10}
    command: "python modelling.py --n_estimators {n_estimators} --min_samples_split {min_samples_split} --min_samples_leaf {min_samples_leaf} --max_depth {max_depth}"